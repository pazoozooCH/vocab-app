# Supabase (cloud — production)
SUPABASE_URL=                  # https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=             # From Supabase project settings → API

# Supabase (local — development/test, populated by `npx supabase start`)
SUPABASE_LOCAL_URL=http://127.0.0.1:54321
SUPABASE_LOCAL_ANON_KEY=       # Printed by `npx supabase start` (Publishable key)

# Claude API (used server-side only, in Vercel serverless function)
ANTHROPIC_API_KEY=

# Supabase MCP (used by Claude Code for database management)
SUPABASE_ACCESS_TOKEN=         # Generate at https://supabase.com/dashboard/account/tokens
SUPABASE_PROJECT_REF=          # Project ID from Supabase project settings → General
