# Supabase — used by the app at runtime (VITE_ prefix exposes them to the browser)
# For local dev, point to local Supabase; for production, point to cloud project
VITE_SUPABASE_URL=http://127.0.0.1:54321          # prod: https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=                            # Printed by `npx supabase start` (Publishable key); prod: from Supabase project settings → API

# Google OAuth (used by both local Supabase and production)
GOOGLE_CLIENT_ID=              # From Google Cloud Console → APIs & Credentials
GOOGLE_CLIENT_SECRET=          # From Google Cloud Console → APIs & Credentials

# Gemini API (used server-side only, in Vercel serverless function)
GEMINI_API_KEY=                # From https://aistudio.google.com/apikey (free tier available)

# Supabase MCP (used by Claude Code for database management)
SUPABASE_ACCESS_TOKEN=         # Generate at https://supabase.com/dashboard/account/tokens
SUPABASE_PROJECT_REF=          # Project ID from Supabase project settings → General
